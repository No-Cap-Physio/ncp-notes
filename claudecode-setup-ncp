<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Claude Code Setup — NCP</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0F1B2D;--np:#162542;--np2:#1E2F4D;--nl:#2A3F5F;
  --nk:#F5F1E8;--nd:#A8B4C4;--nm:#6C7A8F;
  --tan:#D4A574;--td:rgba(212,165,116,0.12);--tb:rgba(212,165,116,0.28);
  --bad:#EF476F;--warn:#FFB703;--wt:#C58A00;--good:#06D6A0;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--navy);color:var(--nk);font-family:'Inter',sans-serif;font-size:14px;line-height:1.8}
/* HEADER */
.hdr{background:var(--np);border-bottom:1px solid var(--nl);padding:16px 24px;position:sticky;top:0;z-index:100;display:flex;align-items:center;gap:16px}
.hdr-logo{font-size:11px;font-weight:800;letter-spacing:2px;color:var(--tan);text-transform:uppercase}
.hdr-title{font-size:15px;font-weight:700;color:var(--nk)}
.hdr-tag{font-size:11px;color:var(--nm);margin-left:auto;background:var(--td);border:1px solid var(--tb);border-radius:4px;padding:2px 8px}
/* TABS */
.tabs{background:var(--np);border-bottom:1px solid var(--nl);padding:0 16px;display:flex;gap:4px;overflow-x:auto;scrollbar-width:none}
.tabs::-webkit-scrollbar{display:none}
.tbtn{background:none;border:none;color:var(--nm);font-family:'Inter',sans-serif;font-size:12px;font-weight:600;padding:10px 14px;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s}
.tbtn:hover{color:var(--nk)}
.tbtn.active{color:var(--tan);border-bottom-color:var(--tan)}
/* CONTENT */
.content{max-width:900px;margin:0 auto;padding:24px 16px}
.tab-panel{display:none}
.tab-panel.active{display:block}
/* SECTION */
.section{margin-bottom:28px}
.sh{display:flex;align-items:center;gap:8px;margin-bottom:12px}
.si{font-size:16px}
.st{font-size:11px;font-weight:800;letter-spacing:2px;color:var(--tan);text-transform:uppercase}
/* CARDS */
.card{background:var(--np);border:1px solid var(--nl);border-radius:8px;padding:16px;margin-bottom:12px}
.card.hi{border-color:var(--tb);background:var(--td)}
.card.warn{border-color:rgba(239,71,111,0.4);background:rgba(239,71,111,0.06)}
.card.flag{border-color:rgba(255,183,3,0.4);background:rgba(255,183,3,0.06)}
.card.good{border-color:rgba(6,214,160,0.4);background:rgba(6,214,160,0.06)}
.ct{font-size:11px;font-weight:700;letter-spacing:1px;color:var(--tan);text-transform:uppercase;margin-bottom:8px}
/* BULLET LIST */
ul.bl{list-style:none;padding:0}
ul.bl li{padding:3px 0 3px 16px;position:relative;color:var(--nd);font-size:13px}
ul.bl li::before{content:"›";position:absolute;left:0;color:var(--tan);font-weight:700}
ul.bl li strong{color:var(--nk);font-weight:600}
ul.bl li em{color:var(--nm);font-style:italic}
.num{color:var(--tan);font-weight:700;text-shadow:0 0 8px rgba(212,165,116,0.4)}
/* PROTOCOL */
.proto{background:var(--np2);border-left:3px solid var(--tan);border-radius:0 6px 6px 0;padding:14px 16px;margin-bottom:12px}
.proto.wp{border-left-color:var(--warn)}
.pn{font-size:10px;font-weight:800;letter-spacing:1.5px;color:var(--tan);text-transform:uppercase;margin-bottom:8px}
.proto.wp .pn{color:var(--wt)}
/* DATA TABLE */
.dtable{width:100%;border-collapse:collapse;font-size:13px}
.dtable th{background:var(--np2);color:var(--nm);font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:8px 12px;text-align:left;border-bottom:1px solid var(--nl)}
.dtable td{padding:8px 12px;border-bottom:1px solid var(--nl);color:var(--nd);vertical-align:top}
.dtable td.val{color:var(--tan);font-weight:700;text-shadow:0 0 8px rgba(212,165,116,0.4)}
/* PRIORITY */
.pri{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:6px;margin-bottom:8px;border:1px solid var(--nl)}
.pri.high{border-color:var(--tb);background:var(--td)}
.pri.mod{background:var(--np)}
.pri.low{background:var(--np);opacity:.7}
.plab{font-size:9px;font-weight:800;letter-spacing:1px;color:var(--tan);text-transform:uppercase;min-width:70px;padding-top:2px}
.pb{font-size:13px;color:var(--nd)}
.pb strong{color:var(--nk)}
/* ACTION GRID */
.agrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.acard{background:var(--np);border:1px solid var(--nl);border-radius:8px;padding:14px}
.alab{font-size:9px;font-weight:800;letter-spacing:1.5px;color:var(--tan);text-transform:uppercase;display:block;margin-bottom:8px}
/* FULL NOTES */
.fn-search{display:flex;gap:8px;margin-bottom:16px;align-items:center}
.fn-search input{flex:1;background:var(--np);border:1px solid var(--nl);border-radius:6px;padding:8px 12px;color:var(--nk);font-family:'Inter',sans-serif;font-size:13px;outline:none}
.fn-search input:focus{border-color:var(--tan)}
.fn-count{font-size:11px;color:var(--nm);white-space:nowrap}
.fn-s{margin-bottom:20px;transition:opacity .2s}
.fn-s.hidden{opacity:.15}
.fn-day{font-size:10px;font-weight:800;letter-spacing:1.5px;color:var(--tan);text-transform:uppercase;margin-bottom:6px}
.fn-head{font-size:12px;font-weight:700;color:var(--nk);margin-bottom:4px;margin-top:10px}
.fn-i{font-size:13px;color:var(--nd);padding:2px 0 2px 14px;position:relative}
.fn-i::before{content:"›";position:absolute;left:0;color:var(--tan)}
.fn-i mark{background:rgba(212,165,116,0.3);color:var(--nk);border-radius:2px;padding:0 2px}
/* NOTION PUSH */
.nblock{background:var(--np);border:1px solid var(--nl);border-radius:8px;overflow:hidden}
.nrow{display:flex;border-bottom:1px solid var(--nl);align-items:flex-start}
.nrow:last-child{border-bottom:none}
.nkey{font-size:10px;font-weight:700;letter-spacing:1px;color:var(--nm);text-transform:uppercase;padding:10px 14px;min-width:140px;border-right:1px solid var(--nl);background:var(--np2)}
.nval{font-size:13px;color:var(--nd);padding:10px 14px;flex:1}
.taglist{display:flex;flex-wrap:wrap;gap:6px;margin-top:4px}
.tag{background:var(--td);border:1px solid var(--tb);border-radius:4px;padding:2px 8px;font-size:11px;color:var(--tan);font-weight:600}
/* CUE */
.cue{background:var(--np2);border-left:3px solid var(--tan);border-radius:0 6px 6px 0;padding:12px 16px;font-style:italic;color:var(--nd);font-size:13px;margin-bottom:12px}
/* PERSONAL NOTES */
.pnotes{margin-top:28px;background:var(--np);border:1px solid var(--nl);border-radius:8px;padding:14px}
.pnlab{font-size:10px;font-weight:700;letter-spacing:1px;color:var(--nm);text-transform:uppercase;display:block;margin-bottom:8px}
.pnotes textarea{width:100%;background:var(--np2);border:1px solid var(--nl);border-radius:6px;color:var(--nk);font-family:'Inter',sans-serif;font-size:13px;padding:10px 12px;resize:vertical;min-height:80px;outline:none}
.pnotes textarea:focus{border-color:var(--tan)}
.psaved{font-size:11px;color:var(--good);margin-top:4px;opacity:0;transition:opacity .3s}
/* GRID UTILS */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:600px){.grid2{grid-template-columns:1fr}.agrid{grid-template-columns:1fr}}
</style>
</head>
