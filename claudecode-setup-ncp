<script>
// TAB SWITCHING
function sw(key,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+key).classList.add('active');
  btn.classList.add('active');
}

// FULL NOTES SEARCH
function fnSearch(){
  const q=document.getElementById('fn-input').value.trim().toLowerCase();
  const sections=document.querySelectorAll('.fn-s');
  let total=0;
  sections.forEach(s=>{
    const items=s.querySelectorAll('.fn-i');
    let sectionMatches=0;
    items.forEach(item=>{
      const txt=item.textContent.toLowerCase();
      if(!q){item.innerHTML=item.textContent;item.style.display='';sectionMatches++;return;}
      if(txt.includes(q)){
        item.innerHTML=item.textContent.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'gi'),m=>`<mark>${m}</mark>`);
        item.style.display='';sectionMatches++;total++;
      } else {item.style.display='none';}
    });
    s.classList.toggle('hidden',q!==''&&sectionMatches===0);
  });
  document.getElementById('fn-count').textContent=q?`${total} match${total!==1?'es':''}`:'' ;
}

// LOCAL STORAGE NOTES
