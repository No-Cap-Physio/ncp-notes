function saveNote(k){
  const ta=document.getElementById('pn-'+k);
  const sv=document.getElementById('sv-'+k);
  try{localStorage.setItem(PREFIX+k,ta.value);sv.style.opacity='1';setTimeout(()=>sv.style.opacity='0',1500);}catch(e){}
}
function loadNotes(){
  ['overview','whatitis','ncpmap','setup','claudemd','rules','alldata','fullnotes','actions','notionpush'].forEach(k=>{
    const ta=document.getElementById('pn-'+k);
    if(!ta)return;
    try{const v=localStorage.getItem(PREFIX+k);if(v)ta.value=v;}catch(e){}
  });
}
loadNotes();
</script>
